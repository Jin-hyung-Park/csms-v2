{
  "name": "csms-ver2-server",
  "version": "0.1.0",
  "description": "CSMS ver2 API server (Express + MongoDB)",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "lint": "echo \"No lint configured\"",
    "seed": "node scripts/seed.js",
    "seed:clear": "node scripts/seed.js --clear",
    "test:api": "node scripts/test-api.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "verify": "node scripts/verify-phase1.js",
    "verify:extended": "node scripts/verify-phase1-extended.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.4",
    "morgan": "^1.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.0.0"
  }
}
