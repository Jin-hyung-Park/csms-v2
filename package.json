{
  "name": "convenience-store-management",
  "version": "1.0.0",
  "description": "CSMS - 편의점 근무 관리 시스템",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:mobile": "concurrently \"npm run server\" \"npm run client:mobile\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "client:mobile": "cd client && npm run start:mobile",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "install:all": "npm install && cd client && npm install",
    "docker:build": "docker build -t convenience-store-management .",
    "docker:run": "docker run -p 5000:5000 convenience-store-management",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "migrate:worklocation": "node server/scripts/migrateWorkLocationToStore.js"
  },
  "keywords": [
    "convenience-store",
    "management",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-error-handler": "^1.1.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.15.0",
    "firebase-admin": "^11.5.0",
    "helmet": "^6.1.5",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.10.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.6.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.2",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.47.0",
    "prettier": "^3.0.2",
    "concurrently": "^8.2.0",
    "@types/jest": "^29.5.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/node_modules/**"
    ]
  }
}
